{
  "name": "niikskate-academy",
  "version": "1.1.0",
  "private": true,
  "description": "NiikSkate Academy - Skateboard class scheduling, booking, and progress tracking app",
  "scripts": {
    "build": "nuxt build",
    "dev": "nuxt dev",
    "dev:host": "nuxt dev --host",
    "dev:clean": "node -e \"require('fs').rmSync('.nuxt',{recursive:true,force:true}); require('fs').rmSync('node_modules/.vite',{recursive:true,force:true}); require('fs').rmSync('node_modules/.cache',{recursive:true,force:true});\" && nuxt dev",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "lint": "eslint .",
    "cap:init": "cap init",
    "cap:add:ios": "cap add ios",
    "cap:add:android": "cap add android",
    "cap:sync": "cap sync",
    "cap:open:ios": "cap open ios",
    "cap:open:android": "cap open android",
    "mobile:build": "npm run generate && npm run cap:sync",
    "niik:parse": "node scripts/parse-niik-library.mjs",
    "stock:parse": "node scripts/parse-stock.cjs"
  },
  "dependencies": {
    "@capacitor/android": "^6.0.0",
    "@capacitor/app": "^6.0.0",
    "@capacitor/core": "^6.0.0",
    "@capacitor/haptics": "^6.0.0",
    "@capacitor/ios": "^6.0.0",
    "@capacitor/keyboard": "^6.0.0",
    "@capacitor/status-bar": "^6.0.0",
    "@nuxt/image": "^1.7.0",
    "@nuxtjs/supabase": "^1.2.2",
    "@pinia/nuxt": "^0.5.1",
    "@vueuse/core": "^10.9.0",
    "@vueuse/nuxt": "^10.9.0",
    "date-fns": "^3.6.0",
    "nuxt": "^3.11.2",
    "pinia": "^2.1.7",
    "vue": "^3.4.27",
    "vue-router": "^4.3.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@capacitor/cli": "^6.0.0",
    "@nuxtjs/tailwindcss": "^6.12.0",
    "@types/node": "^20.12.12",
    "autoprefixer": "^10.4.19",
    "eslint": "^9.3.0",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.3",
    "typescript": "^5.4.5",
    "xlsx": "^0.18.5"
  }
}
